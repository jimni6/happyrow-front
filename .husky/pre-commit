#!/usr/bin/env sh

# Secret scanning: block commits containing potential credentials
SECRETS_PATTERN='(SUPABASE_SERVICE_ROLE|service_role|sk_live|sk_test|-----BEGIN (RSA |EC )?PRIVATE KEY|AKIA[0-9A-Z]{16}|ghp_[A-Za-z0-9]{36}|gho_[A-Za-z0-9]{36}|github_pat_)'

STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.(ts|tsx|js|jsx|json|yml|yaml|env|md|html)$' || true)

if [ -n "$STAGED_FILES" ]; then
  MATCHES=$(echo "$STAGED_FILES" | xargs grep -lEn "$SECRETS_PATTERN" 2>/dev/null || true)
  if [ -n "$MATCHES" ]; then
    echo "ERROR: Potential secrets detected in staged files:"
    echo "$MATCHES"
    echo ""
    echo "If this is a false positive, use: git commit --no-verify"
    exit 1
  fi
fi

npx lint-staged
